<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User List</title>
    <link rel="stylesheet" href="/stylesheets/user_list.css">
</head>
<body>
    <%- include('partials/navbar') %>
    <div class="background">
        <div class="border">
            <main class="container">
                <section class="browse-hero">
                    <h1>User List</h1>
                    <p>Manage and moderate registered users.</p>
                </section>

                <% const userItems = Array.isArray(users) ? users : []; %>
                <section class="browse-results">
                    <div class="results-header">
                        <h2>Registered Users</h2>
                        <p><%= userItems.length %> user(s) found</p>
                    </div>
                    <% if (userItems.length === 0) { %>
                        <div class="empty-state">
                            <p>No users found.</p>
                        </div>
                    <% } else { %>
                        <div class="listing-grid">
                            <% userItems.forEach(function(user) { %>
                                <% const safeUser = user || {}; %>
                                <article class="listing-card">
                                    <div class="listing-meta">
                                        <h3 class="listing-title"><%= safeUser.username || 'Unknown User' %></h3>
                                        <span class="listing-category"><%= safeUser.role || 'user' %></span>
                                    </div>
                                    <p class="listing-description">
                                        <%= [safeUser.firstName, safeUser.lastName].filter(Boolean).join(' ') || 'No name provided' %>
                                        &mdash; <%= safeUser.email || 'No email' %>
                                    </p>
                                    <div class="listing-footer">
                                        <span class="listing-price"><%= safeUser._id %></span>
                                        <button class="btn btnDanger" type="button">Ban</button>
                                    </div>
                                </article>
                            <% }); %>
                        </div>
                    <% } %>
                </section>
            </main>
        </div>
    </div>
</body>
</html>
