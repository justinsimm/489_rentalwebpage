<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User List</title>
    <link rel="stylesheet" href="/stylesheets/user_list.css">
</head>
<body>
    <%- include('partials/navbar') %>
    <div class="background">
        <div class="border">
            <div class="container">
                <header class="page-header">
                    <h1>User List</h1>
                    <p>Manage accounts and review roles.</p>
                </header>

                <!-- Demo Note: Data passed into this view via MVC (users list). -->
                <% const userList = Array.isArray(users) ? users : []; %>
                <table class="user-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Role</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (userList.length === 0) { %>
                            <!-- Demo Note: Empty-state fallback when no users exist. -->
                            <tr>
                                <td colspan="3">No users found.</td>
                            </tr>
                        <% } else { %>
                            <% userList.forEach(function(user) { %>
                                <% const safeUser = user || {}; %>
                                <!-- Demo Note: Loop renders user data with safe fallbacks. -->
                                <tr>
                                    <td><%= safeUser.name || safeUser.username || 'Unnamed User' %></td>
                                    <td><%= safeUser.email || 'No email on file' %></td>
                                    <td><%= safeUser.role || 'User' %></td>
                                </tr>
                            <% }); %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    
</body>
</html>