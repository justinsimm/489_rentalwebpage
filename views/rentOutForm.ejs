<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rent Out an Item</title>
    <link href="/stylesheets/rentOutForm.css" rel="stylesheet">
</head>
<body>
    <%- include('partials/navbar') %>
    <main>
        <div class="background">
            <div class="border">
                <h1>Rent Out Your Item</h1>
                <p class="form-subtitle">Fill out the details below to list your item for rent.</p>

                <form class="rentForm" action="/rentOutForm" method="POST">
                    <div class="formGroup">
                        <label>Item Title</label>
                        <input name="name" type="text" class="form-input">
                    </div>

                    <div class="formGroup">
                        <label>Location</label>
                        <input name="location" type="text" class="form-input">
                    </div>

                    <div class="formGroup">
                        <label>Category</label>
                        <select name="category" class="form-input">
                            <option disabled selected>Select a category</option>
                            <option>Party & Events</option>
                            <option>Tools & Equipment</option>
                            <option>Electronics</option>
                            <option>Sports & Outdoors</option>
                            <option>Apparel & Formal Wear</option>
                            <option>Other</option>
                        </select>
                    </div>

                    <div class="formGroup">
                        <label>Item Description</label>
                        <textarea name= "description" rows="3" class="form-input"></textarea>
                    </div>

                    <div class="formGroup">
                        <label>Daily Rate ($)</label>
                        <input name="dailyRate" type="number" class="form-input">
                    </div>

                    <div class="formGroup fileUpload">
                        <label>Upload Images</label>
                        <input name="image" type="file" class="imgInput" accept=".png, .jpg">
                        <p>Up to 5 photos (PNG or JPG files only). First photo will be the cover image.</p>
                    </div>

                    <div class="mainButtons">
                        <button type="submit" class="btn btnPrimary">List Item for Rent</button>
                        <a href="/my_listings" class="btn btnSecondary">View My Listings</a>
                    </div>
                </form>
            </div>
        </div>
    </main>
</body>

</html>