<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rent Out an Item</title>
    <link href="../public/stylesheets/rentOutForm.css" rel="stylesheet">
</head>
<body>
    <header class="navbar">
        <div class="container navContent">
            <a href="index.ejs" class="logo">Rental Center</a>
            <nav>
                <ul class="navLinks">
                    <li><a href="index.ejs">Home</a></li>
                    <li><a href="browse.ejs">Browse</a></li>
                    <li><a href="rentOutForm.ejs">List Item</a></li>
                    <li><a href="user_inbox.ejs">Inbox</a></li>
                    <li><a href="profile.ejs">Profile</a></li>
                    <li><a href="login.ejs">Login</a></li>
                    <li><a href="signup.ejs" class="active">Sign Up</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <main>
        <div class="background">
            <div class="border">
                <h1>Rent Out Your Item</h1>
                <p class="form-subtitle">Fill out the details below to list your item for rent.</p>

                <form class="rentForm">
                    <div class="formGroup">
                        <label>Item Title</label>
                        <input type="text" class="form-input">
                    </div>

                    <div class="formGroup">
                        <label>Category</label>
                        <select class="form-input">
                            <option disabled selected>Select a category</option>
                            <option>Party & Events</option>
                            <option>Tools & Equipment</option>
                            <option>Electronics</option>
                            <option>Sports & Outdoors</option>
                            <option>Apparel & Formal Wear</option>
                            <option>Other</option>
                        </select>
                    </div>

                    <div class="formGroup">
                        <label>Item Description</label>
                        <textarea rows="3" class="form-input"></textarea>
                    </div>

                    <div class="formGroup">
                        <label>Daily Rate ($)</label>
                        <input type="number" class="form-input">
                    </div>

                    <div class="formGroup fileUpload">
                        <label>Upload Images</label>
                        <input type="file" class="imgInput" accept=".png, .jpg">
                        <p>Up to 5 photos (PNG or JPG files only). First photo will be the cover image.</p>
                    </div>

                    <div class="mainButtons">
                        <button type="submit" class="btn btnPrimary">List Item for Rent</button>
                        <a href="my_listings.html" class="btn btnSecondary">View My Listings</a>
                    </div>
                </form>
            </div>
        </div>
    </main>
</body>

</html>