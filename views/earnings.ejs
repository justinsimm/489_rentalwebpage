<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Your Earnings</title>
    <link href="/stylesheets/earnings.css" rel="stylesheet">
</head>
<body>
    <%- include('partials/navbar') %>
    <main>
        <div class="background">
            <div class="border">
                <h1>Earnings Dashboard</h1>
                <p class="form-subtitle">Review your revenue and transaction history.</p>

                <form class="rentForm">
                    <div class="formGroup">
                        <label>All-Time Earnings</label>
                        <input type="text" class="form-input" value="$1,250.00">
                    </div>

                    <div class="formGroup">
                        <label>Earnings (Last 30 Days)</label>
                        <input type="text" class="form-input" value="$450.00">
                    </div>

                    <div class="formGroup">
                        <label>Transaction History</label>
                        <textarea class="form-input">
                            Date: 3/6/2026 - Rented: Bouncy House - Revenue: $150.00
                            Date: 3/4/2026 - Rented: Chairs (x20) - Revenue: $50.00
                            Date: 2/23/2026 - Rented: Tent - Revenue: $250.00
                        </textarea>
                    </div>

                    <div class="mainButtons">
                        <a href="/profile" class="btn btnSecondary">Back to Profile</a>
                    </div>
                </form>
            </div>
        </div>
    </main>
</body>

</html>