<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Checkout</title>
    <link rel="stylesheet" href="/stylesheets/checkout.css">
</head>
<body>
    <header class="navbar">
        <div class="container navContent">
            <a href="/" class="logo">Rental Center</a>
            <nav>
                <ul class="navLinks">
                    <li><a href="/">Home</a></li>
                    <li><a href="/browse">Browse</a></li>
                    <li><a href="/rentOutForm">List Item</a></li>
                    <li><a href="/user_inbox">Inbox</a></li>
                    <li><a href="/profile">Profile</a></li>
                    <li><a href="/my_listings">My Listings</a></li>
                    <li><a href="/login">Login</a></li>
                    <li><a href="/signup">Sign Up</a></li>
                </ul>
            </nav>
        </div>
    </header>
    
    <div class="background">
        <div class="border">
            <div class="container">
                <h1>Checkout</h1>
                <div class="checkout_form">
                    <h2>Shipping Address</h2>
                    <label for="text_box">Full Name:</label>
                    <input class="text_box">
                    <label for="text_box">Street Address:</label>
                    <input class="text_box">
                    <label for="text_box">City:</label>
                    <input class="text_box">
                    <label for="text_box">State:</label>
                    <input class="text_box">
                    <label for="text_box">ZIP Code:</label>
                    <input class="text_box">
                    <label for="text_box">Phone Number:</label>
                    <input class="text_box">

                    <h2>Billing Address</h2>
                    <label for="text_box">Same as shipping:</label>
                    <input type="checkbox">
                    <label for="text_box">Full Name:</label>
                    <input class="text_box">
                    <label for="text_box">Street Address:</label>
                    <input class="text_box">
                    <label for="text_box">City:</label>
                    <input class="text_box">
                    <label for="text_box">State:</label>
                    <input class="text_box">
                    <label for="text_box">ZIP Code:</label>
                    <input class="text_box">

                    <h2>Payment Info</h2>
                    <label for="text_box">Credit Card Number:</label>
                    <input class="text_box">
                    <label for="text_box">Name on Card:</label>
                    <input class="text_box">
                    <label for="text_box">Expiration Date (MM/YY):</label>
                    <input class="text_box">
                    <label for="text_box">CVV (3-4 digits):</label>
                    <input class="text_box">
                    <label for="text_box">Card Type:</label>
                    <input class="text_box">
                    <label for="text_box">Card Type:</label>
                    <select id="card-type" name="card_type">
                        <option value="Visa">Visa</option>
                        <option value="mastercard">MasterCard</option>
                        <option value="american_express">American Express</option>
                        <option value="discover">Discover</option>
                    </select>

                    <h2>Cart</h2>
                    <div class="cart_container">
                        <p>Lawn Mower: $10</p>
                        <p>Service Fee: $2</p>
                        <p>Tax: $0.80</p>
                        <p>Total: $12.80</p>
                    </div>
                    <div class="mainButtons">
                        <button class="btn btnPrimary" type="button">Place Order</button>
                        <a class="btn btnSecondary" href="/browse">Back to Browse</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

</body>
</html>