<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up</title>
    <link rel="stylesheet" href="/stylesheets/signup.css">
</head>
<body>
    <%- include('partials/navbar') %>
    <div class="background">
        <div class="border">
            <main class="container">
                <section>
                    <h1>Create Account</h1>
                    <p>Join the community to list and reserve equipment.</p>
                    
                    <% if (errors.length > 0) { %>
                        <div class="alert alert-danger">
                            <p><%= errors[0] %></p>
                        </div>
                    <% } %>

                    <% if (success) { %>
                        <div class="alert alert-success">
                            <p>Signature successfully added</p>
                        </div>
                    <% } %>

                    <form action="/signup" method="POST" novalidate>
                        <div class="formGroup">
                            <label for="signupFirst">First Name</label>
                            <input id="signupFirst" name="firstName" type="text" placeholder="First name" value="<%= formData.firstName %>">
                        </div>
                        <div class="formGroup">
                            <label for="signupLast">Last Name</label>
                            <input id="signupLast" name="lastName" type="text" placeholder="Last name" value="<%= formData.lastName %>">
                        </div>
                        <div class="formGroup">
                            <label for="signupUsername">Username</label>
                            <input id="signupUsername" name="username" type="text" placeholder="username" value="<%= formData.username %>">
                        </div>
                        <div class="formGroup">
                            <label for="signupEmail">Email</label>
                            <input id="signupEmail" name="email" type="email" placeholder="you@example.com" value="<%= formData.email %>">
                        </div>
                        <div class="formGroup">
                            <label for="signupPassword">Password</label>
                            <input id="signupPassword" name="password" type="password" placeholder="At least 8 characters" value="<%= formData.password %>">
                        </div>
                        <div class="mainButtons">
                            <button type="submit" class="btn btnPrimary">Create Account</button>
                            <a href="/login" class="btn btnSecondary">Already have an account?</a>
                        </div>
                    </form>
                </section>
            </main>
        </div>
    </div>

    <script src="../js/app.js"></script>
</body>
</html>
