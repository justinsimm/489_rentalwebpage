<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Listings</title>
    <link rel="stylesheet" href="/stylesheets/my_listing.css">
</head>
<body>
    <%- include('partials/navbar') %>
    <div class="background">
        <div class="border">
            <main class="container">
                <section>
                    <h1>My Listings</h1>
                    <p>Manage items you have listed for rent.</p>

                    <table>
                        <thead>
                            <tr>
                                <th>Item</th>
                                <th>Category</th>
                                <th>Status</th>
                                <th>Daily Rate</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Leaf Blower</td>
                                <td>Tools & Equipment</td>
                                <td>Available</td>
                                <td>$12</td>
                                <td>
                                    <button class="btn btnSecondary">Edit</button>
                                    <button class="btn btnSecondary">Pause</button>
                                </td>
                            </tr>
                            <tr>
                                <td>Party Tent</td>
                                <td>Party & Events</td>
                                <td>Reserved</td>
                                <td>$60</td>
                                <td>
                                    <button class="btn btnSecondary">View Reservation</button>
                                </td>
                            </tr>
                            <tr>
                                <td>Snowboard</td>
                                <td>Sports & Outdoors</td>
                                <td>Inactive</td>
                                <td>$15</td>
                                <td>
                                    <button class="btn btnSecondary">Reactivate</button>
                                </td>
                            </tr>
                        </tbody>
                    </table>

                    <div class="mainButtons">
                        <a href="/rentOutForm" class="btn btnPrimary">List a New Item</a>
                        <a href="/profile" class="btn btnSecondary">Back to Profile</a>
                    </div>
                </section>
            </main>
        </div>
    </div>

    <script src="../js/app.js"></script>
</body>
</html>
