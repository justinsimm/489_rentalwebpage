<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Listings</title>
    <link rel="stylesheet" href="/stylesheets/my_listing.css">
</head>
<body>
    <%- include('partials/navbar') %>
    <div class="background">
        <div class="border">
            <main class="container">
                <section>
                    <h1>My Listings</h1>
                    <p>Manage items you have listed for rent.</p>

                    <% if (items.length === 0) { %>
                        <div class="emptyState">
                            <p>You haven't listed any items yet.</p>
                            <p>Click the button below to list your first item!</p>
                        </div>
                    <% } else { %>
                        <table>
                            <thead>
                                <tr>
                                    <th>Item</th>
                                    <th>Category</th>
                                    <th>Status</th>
                                    <th>Daily Rate</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% items.forEach(function(item) { %>
                                    <tr>
                                        <td><%= item.name %></td>
                                        <td><%= item.category %></td>
                                        <td><%= item.status %></td>
                                        <td>$<%= item.dailyRate %></td>
                                        <td>
                                            <a href="/item/<%= item._id %>" class="btn btnSecondary">View</a>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    <% } %>

                    <div class="mainButtons">
                        <a href="/rentOutForm" class="btn btnPrimary">List a New Item</a>
                        <a href="/profile" class="btn btnSecondary">Back to Profile</a>
                    </div>
                </section>
            </main>
        </div>
    </div>

    <script src="../js/app.js"></script>
</body>
</html>
