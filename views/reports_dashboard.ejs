<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reports Dashboard</title>
    <link rel="stylesheet" href="/stylesheets/admin_home.css">
</head>
<body>
    <%- include('partials/navbar') %>
    <div class="background">
        <div class="border">
            <div class="container">
                <h1>Reports Dashboard</h1>
                <p>Review reported listings and take moderation actions.</p>

                <!-- Demo Note: Data passed into this view via MVC (reports list). -->
                <% const reportList = Array.isArray(reports) ? reports : []; %>
                <% const formatDate = function(value) {
                    if (!value) { return 'TBD'; }
                    const date = new Date(value);
                    return isNaN(date.getTime()) ? String(value) : date.toLocaleDateString();
                }; %>

                <table>
                    <!-- Demo Note: Table renders reports with safe fallbacks. -->
                    <thead>
                        <tr>
                            <th>Item</th>
                            <th>Reason</th>
                            <th>Status</th>
                            <th>Date</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (reportList.length === 0) { %>
                            <!-- Demo Note: Empty-state fallback when no reports exist. -->
                            <tr>
                                <td colspan="5">No reports available.</td>
                            </tr>
                        <% } else { %>
                            <% reportList.forEach(function(report) { %>
                                <% const safeReport = report || {}; %>
                                <tr>
                                    <td><%= safeReport.itemName || (safeReport.item && safeReport.item.name) || 'Item not listed' %></td>
                                    <td><%= safeReport.reason || 'No reason provided' %></td>
                                    <td><%= safeReport.status || 'Open' %></td>
                                    <td><%= formatDate(safeReport.date || safeReport.createdAt) %></td>
                                    <td>
                                        <!-- Demo Note: Action buttons are placeholders for moderation logic. -->
                                        <button class="btn btnPrimary" type="button">View</button>
                                        <button class="btn btnSecondary" type="button">Resolve</button>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } %>
                    </tbody>
                </table>

                <div class="mainButtons">
                    <a href="/admin_home" class="btn btnSecondary">Back to Admin Home</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
