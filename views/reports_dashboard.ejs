<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reports Dashboard</title>
    <link rel="stylesheet" href="../public/stylesheets/admin_home.css">
</head>
<body>
    <header class="navbar">
        <div class="container navContent">
            <a href="index.ejs" class="logo">Rental Center</a>
            <nav>
                <ul class="navLinks">
                    <li><a href="reports_dashboard.ejs" class="active" >Reports</a></li>
                    <li><a href="browse.ejs">Browse</a></li>
                    <li><a href="rentOutForm.ejs">List Item</a></li>
                    <li><a href="user_inbox.ejs">Inbox</a></li>
                    <li><a href="profile.ejs" class="active">Profile</a></li>
                    <li><a href="login.ejs">Login</a></li>
                    <li><a href="signup.ejs">Sign Up</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <div class="background">
        <div class="border">
            <div class="container">
                <h1>Reports Dashboard</h1>
                <p>Review reported listings and take moderation actions.</p>

                <table>
                    <thead>
                        <tr>
                            <th>Report ID</th>
                            <th>Item</th>
                            <th>Reason</th>
                            <th>Reporter</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>R-1021</td>
                            <td>Leaf Blower</td>
                            <td>Inappropriate Listing</td>
                            <td>user_419</td>
                            <td>Open</td>
                            <td>
                                <button class="btn btnPrimary">View</button>
                                <button class="btn btnSecondary">Remove Listing</button>
                            </td>
                        </tr>
                        <tr>
                            <td>R-1022</td>
                            <td>Party Tent</td>
                            <td>Misleading Details</td>
                            <td>event_planner</td>
                            <td>Open</td>
                            <td>
                                <button class="btn btnPrimary">View</button>
                                <button class="btn btnSecondary">Dismiss</button>
                            </td>
                        </tr>
                        <tr>
                            <td>R-1019</td>
                            <td>Snowboard</td>
                            <td>Scam Attempt</td>
                            <td>kate88</td>
                            <td>Resolved</td>
                            <td><button class="btn btnSecondary">Reopen</button></td>
                        </tr>
                    </tbody>
                </table>

                <div class="mainButtons">
                    <a href="admin_home.html" class="btn btnSecondary">Back to Admin Home</a>
                </div>
            </div>
        </div>
    </div>

    <script src="../js/app.js"></script>
</body>
</html>
