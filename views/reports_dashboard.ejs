<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reports Dashboard</title>
    <link rel="stylesheet" href="/stylesheets/admin_home.css">
</head>
<body>
    <%- include('partials/navbar') %>
    <div class="background">
        <div class="border">
            <div class="container">
                <h1>Reports Dashboard</h1>
                <p>Review reported listings and take moderation actions.</p>

                <% const openReports = reports.filter(function(r) { 
                    return r.status === 'Open'; 
                }); 
                %>
                <% const resolvedReports = reports.filter(function(r) { 
                    return r.status === 'Resolved'; 
                }); 
                %>

                <div class="recentSection">
                    <h3>Open Reports</h3>
                    <% if (openReports.length === 0) { %>
                        <p class="emptyText">No open reports.</p>
                    <% } else { %>
                        <table>
                            <thead>
                                <tr>
                                    <th>Reported User</th>
                                    <th>Item</th>
                                    <th>Reason</th>
                                    <th>Reporter</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% openReports.forEach(function(report) { %>
                                    <tr>
                                        <td><%= report.reportedUser %></td>
                                        <td><%= report.item ? report.item.name : 'N/A' %></td>
                                        <td><%= report.reason %></td>
                                        <td><%= report.reporterName || 'Unknown' %></td>
                                        <td>
                                            <% if (report.item) { %>
                                                <a href="/item/<%= report.item._id %>" class="btn btnPrimary">View</a>
                                            <% } %>
                                            <form method="POST" action="/reports_dashboard/<%= report._id %>/resolve" class="inlineForm">
                                                <input type="hidden" name="action" value="resolve">
                                                <button type="submit" class="btn btnSecondary">Resolve</button>
                                            </form>
                                            <% if (report.item) { %>
                                                <form method="POST" action="/reports_dashboard/<%= report._id %>/resolve" class="inlineForm">
                                                    <input type="hidden" name="action" value="remove">
                                                    <button type="submit" class="btn btnDanger">Remove & Notify</button>
                                                </form>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    <% } %>
                </div>

                <div class="recentSection">
                    <h3>Resolved Reports</h3>
                    <% if (resolvedReports.length === 0) { %>
                        <p class="emptyText">No resolved reports yet.</p>
                    <% } else { %>
                        <table>
                            <thead>
                                <tr>
                                    <th>Reported User</th>
                                    <th>Item</th>
                                    <th>Reason</th>
                                    <th>Reporter</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% resolvedReports.forEach(function(report) { %>
                                    <tr>
                                        <td><%= report.reportedUser %></td>
                                        <td><%= report.item ? report.item.name : 'N/A' %></td>
                                        <td><%= report.reason %></td>
                                        <td><%= report.reporterName || 'Unknown' %></td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    <% } %>
                </div>

                <div class="mainButtons">
                    <a href="/admin_home" class="btn btnSecondary">Back to Admin Home</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
