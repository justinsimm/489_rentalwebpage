<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rental System Item</title>
    <link rel="stylesheet" href="/stylesheets/item.css">
</head>
<body>
    <%- include('partials/navbar') %>
    <div class="background">
        <div class="border">
           <article class="item-card">

                <% const safeItem = item || {}; %>
                <div class="item-meta">
                    <h1 class="item-title"><%= safeItem.name ? safeItem.name.charAt(0).toUpperCase() + safeItem.name.slice(1) : 'Item Details' %></h1>
                    <% const status = safeItem.status || 'Unavailable'; %>
                    <span class="status-badge status-<%= status.toLowerCase().replace(/\s+/g, '-') %>"><%= status %></span>
                </div>

                <% if (safeItem.image) { %>
                <div class="item-image">
                    <img src="<%= safeItem.image %>" alt="<%= safeItem.name || 'Item image' %>">
                </div>
                <% } %>

                <div class="item-info-grid">
                    <div class="info-row">
                        <span class="info-label">Owner</span>
                        <span class="info-value"><%= safeItem.owner || 'Unknown' %></span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Daily Rate</span>
                        <span class="info-value info-price"><%= (safeItem.dailyRate != null && String(safeItem.dailyRate).trim() !== '') ? '$' + safeItem.dailyRate + '/day' : 'N/A' %></span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Pickup Location</span>
                        <span class="info-value"><%= safeItem.location || 'N/A' %></span>
                    </div>
                    <% if (safeItem.category) { %>
                    <div class="info-row">
                        <span class="info-label">Category</span>
                        <span class="info-value"><%= safeItem.category %></span>
                    </div>
                    <% } %>
                </div>
                <% if (safeItem.details) { %>
                <div class="item-notes">
                    <p class="notes-label">Notes</p>
                    <p class="notes-body"><%= safeItem.details %></p>
                </div>
                <% } %>

                <div class="item-footer">
                    <% if (safeItem.status === 'Available') { %>
                        <a href="/rentItem/<%= safeItem._id || safeItem.id %>" class="btn btnPrimary">Rent Item</a>
                    <% } else { %>
                        <button class="btn btnPrimary" disabled>Currently Unavailable</button>
                    <% } %>
                    <a href="/report" class="btn btnSecondary">Report Listing</a>
                </div>

            </article>
        </div>
    </div>
</body>
</html>