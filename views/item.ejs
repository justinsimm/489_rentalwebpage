<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rental System Item</title>
    <link rel="stylesheet" href="/stylesheets/item.css">
</head>
<body>
    <%- include('partials/navbar') %>
    <div class="background">
        <div class="border">
            <div class="container">
                <section>
                    <!--Header-->
                    <% const safeItem = item || {}; %>
                    <div class="item header">
                        <h1><%= safeItem.name ? safeItem.name.charAt(0).toUpperCase() + safeItem.name.slice(1) : 'Item Details' %></h1>
                    </div>

                    <!--Image-->
                    <div class="item-image">
                        <img src="<%= safeItem.image || '' %>">
                    </div>
                    
                    <!--Item details-->
                    <div class="item-details">
                        <p><strong>Owner:</strong> <%= safeItem.owner || 'Unknown' %></p>
                        <p><strong>Daily Rate:</strong> <%= (safeItem.dailyRate !== undefined && safeItem.dailyRate !== null && String(safeItem.dailyRate).trim() !== '') ? safeItem.dailyRate : 'N/A' %></p>
                        <p><strong>Location:</strong> <%= safeItem.location || 'N/A' %></p>
                        <p><strong>Status:</strong> <%= safeItem.status || 'Unavailable' %></p>
                        <strong>Notes</strong>
                        <p> <%= safeItem.details || 'No additional details.' %> </p>
                    </div>

                    <div class="mainButtons">
                        <% if (safeItem.status === 'Available') { %>
                            <a href="/rentItem/<%= safeItem._id || safeItem.id %>" class="btn btnPrimary">Rent Item</a>
                        <% } else { %>
                            <button class="btn btnPrimary" disabled>Currently Unavailable</button>
                        <% } %>
                        <a href="/report" class="btn btnSecondary">Report Listing</a>
                    </div>
                </section>
            </div>
        </div>
    </div>
    
</body>
</html>