<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rental System Item</title>
    <link rel="stylesheet" href="/stylesheets/item.css">
</head>
<body>
    <header class="navbar">
        <div class="container navContent">
            <a href="/" class="logo">Rental Center</a>
            <nav>
                <ul class="navLinks">
                    <li><a href="/">Home</a></li>
                    <li><a href="/browse" class="active">Browse</a></li>
                    <li><a href="/rentOutForm">List Item</a></li>
                    <li><a href="/user_inbox">Inbox</a></li>
                    <li><a href="/profile">Profile</a></li>
                    <li><a href="/my_listings">My Listings</a></li>
                    <li><a href="/login">Login</a></li>
                    <li><a href="/signup">Sign Up</a></li>
                </ul>
            </nav>
        </div>
    </header>
    <div class="background">
        <div class="border">
            <div class="container">
                <section>
                    <!--Header-->
                    <div class="item header">
                        <h1><%= item.name %></h1>
                    </div>

                    <!--Image-->
                    <div class="item-image">
                        <img src="<%= item.imageUrl %>" alt="<%= item.name %>">
                    </div>
                    
                    <!--Item details-->
                    <div class="item-details">
                        <p><strong>Owner:</strong> <%= item.owner %></p>
                        <p><strong>Daily Rate:</strong> <%= item.dailyRate %></p>
                        <p><strong>Location:</strong> <%= item.location %></p>
                        <p><strong>Status:</strong> <%= item.status %></p>
                        <strong>Notes</strong>
                        <p> <%= item.details %></p>
                    </div>

                    <h3>Availability Calendar</h3>
                    <ul>
                        <li>Available: 3/10 - 3/14</li>
                        <li>Reserved: 3/15 - 3/16</li>
                        <li>Available: 3/17 onward</li>
                    </ul>

                    <div class="mainButtons">
                        <% if (item.status === 'Available') { %>
                            <a href="/checkout?itemId=<%= item.id %>" class="btn btnPrimary">Checkout</a>
                        <% } else { %>
                            <button class="btn btnPrimary" disabled>Currently Unavailable</button>
                        <% } %>
                        <a href="/report_form" class="btn btnSecondary">Report Listing</a>
                    </div>

                    <h3>Reviews</h3>
                    <ul>
                        <li><strong>campus_club:</strong> Great condition, easy pickup.</li>
                        <li><strong>event_planner:</strong> Owner was responsive and helpful.</li>
                        <li><strong>kate88:</strong> Clean and sturdy. Would rent again.</li>
                    </ul>
                </section>
            </div>
        </div>
    </div>
    

    <script src="../js/app.js"></script>
</body>
</html>