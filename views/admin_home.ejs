<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Home</title>
    <link rel="stylesheet" href="/stylesheets/admin_home.css">
</head>
<body>
    <%- include('partials/navbar') %>
    <div class="background">
        <div class="border">
            <div class="container">
                <h1>Admin Dashboard</h1>
                <p>System overview and moderation insights.</p>
                <div class="report-item">
                    <div class="report-text">
                        <h3>Daily Rentals:</h3>
                        <p>Today: 14 rentals</p>
                        <p>Peak Hour: 4pm - 6pm</p>
                    </div>
                    <div class="report-figure">
                        <p>Chart Placeholder</p>
                    </div>
                </div>
                <div class="report-item">
                    <div class="report-text">
                        <h3>Weekly Rentals:</h3>
                        <p>Total: 76 rentals</p>
                        <p>Most Popular: Party & Events</p>
                    </div>
                    <div class="report-figure">
                        <p>Chart Placeholder</p>
                    </div>
                </div>
                <div class="report-item">
                    <div class="report-text">
                        <h3>Weekly Incidents:</h3>
                        <p>Open Reports: 5</p>
                        <p>Resolved This Week: 12</p>
                    </div>
                    <div class="report-figure">
                        <p>Chart Placeholder</p>
                    </div>
                </div>
                <div class="mainButtons">
                    <a href="/reports_dashboard" class="btn btnPrimary">View Reports</a>
                    <a href="/user_management" class="btn btnSecondary">Manage Users</a>
                </div>
            </div>
        </div>
    </div>

    <script src="../js/app.js"></script>
</body>
</html>