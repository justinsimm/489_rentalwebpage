<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Inbox</title>
    <link rel="stylesheet" href="/stylesheets/admin_inbox.css">
</head>
<body>
    <%- include('partials/navbar') %>
    <div class="background">
        <div class="border">
            <div class="container">
                <h1>Admin Inbox</h1>
                <p>System alerts and action logs from report resolutions.</p>

                <div class="recentSection">
                    <h3>System Alerts</h3>
                    <% if (alerts.length === 0) { %>
                        <p class="emptyText">No alerts yet. Alerts will appear here when you resolve reports.</p>
                    <% } else { %>
                        <% alerts.forEach(function(alert) { %>
                            <div class="alertCard">
                                <p class="alertMessage"><%= alert.message %></p>
                            </div>
                        <% }); %>
                    <% } %>
                </div>

                <div class="mainButtons">
                    <a href="/admin_home" class="btn btnSecondary">Back to Admin Home</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>