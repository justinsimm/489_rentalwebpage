<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Inbox</title>
    <link rel="stylesheet" href="/stylesheets/admin_inbox.css">
</head>
<body>
    <header class="navbar">
        <div class="container navContent">
            <a href="/" class="logo">Rental Center</a>
            <nav>
                <ul class="navLinks">
                    <li><a href="/admin_home">Home</a></li>
                    <li><a href="/reports_dashboard">Reports</a></li>
                    <li><a href="/user_list">Users</a></li>
                    <li><a href="/admin_inbox" class="active">Inbox</a></li>
                    <li><a href="/browse">Browse</a></li>
                    <li><a href="/profile">Profile</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <div class="background">
        <div class="border">
            <div class="container">
                <h1>Inbox</h1>
                <div class="filter-row">
                    <h3 class="inbox_filter">Reports</h3>
                    <h3 class="inbox_filter">Messages</h3>
                    <h3 class="inbox_filter">Issues</h3>
                </div>
                <div class="inbox_container">
                    <div class="messages-list">
                        <p class="message-item">[Report] Leaf Blower — Inappropriate Listing</p>
                        <p class="message-item">[Report] Party Tent — Misleading Details</p>
                        <p class="message-item">[Message] event_planner — Pickup update</p>
                        <p class="message-item">[Issue] kate88 — Payment dispute</p>
                    </div>
                    <div class="message-detail">
                        <h3>Details</h3>
                        <p><strong>Type:</strong> Report</p>
                        <p><strong>Item:</strong> Leaf Blower</p>
                        <p><strong>Reporter:</strong> user_419</p>
                        <p><strong>Reason:</strong> Inappropriate Listing</p>
                        <p><strong>Notes:</strong> Listing includes unrelated content and pricing.</p>
                        <div class="mainButtons">
                            <button class="btn btnPrimary" type="button">Open Report</button>
                            <button class="btn btnSecondary" type="button">Dismiss</button>
                        </div>
                    </div>
                </div>
                
            </div>
        </div>
    </div>
    <script src="../js/app.js"></script>
</body>
</html>