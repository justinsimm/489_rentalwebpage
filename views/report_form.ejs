<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Report Form</title>
    <link rel="stylesheet" href="/stylesheets/report_form.css">
</head>
<body>
    <%- include('partials/navbar') %>
    <div class="background">
        <div class="border">
            <div class="container">
                <h1>Report Form</h1>

                <% if (success) { %>
                    <div class="successMessage">
                        <h3>Thank you for your report!</h3>
                        <p>Your report has been sent to our admin and moderators for review.</p>
                        <p>Redirecting you back to browsing...</p>
                    </div>
                    <script>
                        setTimeout(function() {
                            window.location = '/browse';
                        }, 2000);
                    </script>
                <% } else { %>
                    <% if (errors.length > 0) { %>
                        <div class="alert alert-danger">
                            <p><%= errors[0] %></p>
                        </div>
                    <% } %>

                    <form method="POST" action="/report" novalidate>
                        <input type="hidden" name="itemId" value="<%= itemId || '' %>">

                        <% if (item) { %>
                            <div class="itemContext">
                                <p><strong>Reporting Item:</strong> <%= item.name %></p>
                                <p><strong>Listed by:</strong> <%= item.owner %></p>
                            </div>
                        <% } %>

                        <label for="reported-user">User Reported:</label>
                        <input id="reported-user" name="reportedUser" type="text" class="textInput" placeholder="username or listing owner" value="<%= formData.reportedUser %>" <%= item ? 'readonly' : '' %>>

                        <label for="report_reason">Rule Broken:</label>
                        <select id="report_reason" name="reason">
                            <option value="inappropriate_item" <%= formData.reason === 'inappropriate_item' ? 'selected' : '' %>>Inappropriate Item</option>
                            <option value="inappropriate_username" <%= formData.reason === 'inappropriate_username' ? 'selected' : '' %>>Inappropriate Username</option>
                            <option value="user_scam" <%= formData.reason === 'user_scam' ? 'selected' : '' %>>Scamming</option>
                            <option value="unrelated_details" <%= formData.reason === 'unrelated_details' ? 'selected' : '' %>>Unrelated Details</option>
                        </select>

                        <label for="further_details">Details:</label>
                        <textarea id="further_details" name="details" placeholder="Further Details (optional)"><%= formData.details %></textarea>

                        <div class="mainButtons">
                            <button type="submit" class="btn btnPrimary">Submit Report</button>
                            <a href="/browse" class="btn btnSecondary">Cancel</a>
                        </div>
                    </form>
                <% } %>
            </div>
        </div>
    </div>
</body>
</html>