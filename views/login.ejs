<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>
    <link rel="stylesheet" href="../public/stylesheets/login.css">
</head>
<body>
    <header class="navbar">
        <div class="container navContent">
            <a href="index.ejs" class="logo">Rental Center</a>
            <nav>
                <ul class="navLinks">
                    <li><a href="index.ejs">Home</a></li>
                    <li><a href="browse.ejs">Browse</a></li>
                    <li><a href="rentOutForm.ejs">List Item</a></li>
                    <li><a href="user_inbox.ejs">Inbox</a></li>
                    <li><a href="profile.ejs">Profile</a></li>
                    <li><a href="login.ejs" class="active">Login</a></li>
                    <li><a href="signup.ejs">Sign Up</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <div class="background">
        <div class="border">
            <main class="container">
                <section>
                    <h1>Login</h1>
                    <p>Access your account to reserve items, manage listings, and view messages.</p>
                    <form>
                        <div>
                            <label for="login-email">Email</label><br>
                            <input id="login-email" type="email" placeholder="you@example.com">
                        </div>
                        <div>
                            <label for="login-password">Password</label><br>
                            <input id="login-password" type="password" placeholder="••••••••">
                        </div>
                        <div class="mainButtons">
                            <button type="submit" class="btn btnPrimary">Log In</button>
                            <a href="signup.html" class="btn btnSecondary">Create Account</a>
                        </div>
                        <p><a href="#">Forgot password?</a></p>
                    </form>
                </section>
            </main>
        </div>
    </div>

    <script src="../js/app.js"></script>
</body>
</html>
