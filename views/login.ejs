<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>
    <link rel="stylesheet" href="/stylesheets/login.css">
</head>
<body>
    <header class="navbar">
        <div class="container navContent">
            <a href="/" class="logo">Rental Center</a>
            <nav>
                <ul class="navLinks">
                    <li><a href="/">Home</a></li>
                    <li><a href="/browse">Browse</a></li>
                    <li><a href="/rentOutForm">List Item</a></li>
                    <li><a href="/user_inbox">Inbox</a></li>
                    <li><a href="/profile">Profile</a></li>
                    <li><a href="/login" class="active">Login</a></li>
                    <li><a href="/signup">Sign Up</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <div class="background">
        <div class="border">
            <main class="container">
                <section>
                    <h1>Login</h1>
                    <p>Access your account to reserve items, manage listings, and view messages.</p>
                    <form action="/login" method="POST">
                        <div class="formGroup">
                            <label for="login-username">Username</label><br>
                            <input id="login-username" name="username" type="username" placeholder="">
                        </div>
                        <div class="formGroup">
                            <label for="login-password">Password</label><br>
                            <input id="login-password" name="password" type="password" placeholder="••••••••">
                        </div>
                        <div class="mainButtons">
                            <button type="submit" class="btn btnPrimary">Log In</button>
                            <a href="/signup" class="btn btnSecondary">Create Account</a>
                        </div>
                    </form>
                </section>
            </main>
        </div>
    </div>

</body>
</html>
