<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rental Center Browse</title>
    <link rel="stylesheet" href="/stylesheets/browse.css">
</head>
<body>
    <header class="navbar">
        <div class="container navContent">
            <a href="/" class="logo">Rental Center</a>
            <nav>
                <ul class="navLinks">
                    <li><a href="/">Home</a></li>
                    <li><a href="/browse" class="'active">Browse</a></li>
                    <li><a href="/rentOutForm">List Item</a></li>
                    <li><a href="/user_inbox">Inbox</a></li>
                    <li><a href="/profile">Profile</a></li>
                    <li><a href="/my_listings">My Listings</a></li>
                    <li><a href="/login">Login</a></li>
                    <li><a href="/signup">Sign Up</a></li>
                </ul>
            </nav>
        </div>
    </header>
    <div class="background">
        <div class="border">
            <main class="container">
                <section>
                    <h1>Browse Listings</h1>
                    <p>Search and filter available rentals in your community.</p>
                    <div>
                        <label for="search-input">Search</label><br>
                        <input id="search-input" type="text" placeholder="Search by keyword or item name">
                        <button class="btn btnPrimary" type="button">Search</button>
                    </div>
                    <div>
                        <label for="category-filter">Category</label><br>
                        <select id="category-filter">
                            <option>All Categories</option>
                            <option>Party & Events</option>
                            <option>Tools & Equipment</option>
                            <option>Electronics</option>
                            <option>Sports & Outdoors</option>
                            <option>Apparel & Formal Wear</option>
                        </select>
                        <label for="distance-filter">Distance</label><br>
                        <select id="distance-filter">
                            <option>Within 5 miles</option>
                            <option>Within 10 miles</option>
                            <option>Within 25 miles</option>
                            <option>Within 50 miles</option>
                        </select>
                        <label for="availability-filter">Availability</label><br>
                        <select id="availability-filter">
                            <option>Any Date</option>
                            <option>This Week</option>
                            <option>This Weekend</option>
                            <option>Next 30 Days</option>
                        </select>
                    </div>
                    <div>
                        <h3>Featured Listings</h3>
                        <ul class="featureListings">
                            <li><a href="item.html">Lawn Mower</a> — $10/day — Available this weekend</li>
                            <li><a href="item.html">Party Tent</a> — $60/day — Available 3/10-3/14</li>
                            <li><a href="item.html">Snowboard</a> — $15/day — Available next week</li>
                        </ul>
                    </div>
                </section>
            </main>
        </div>
    </div>
    <script src="../js/app.js"></script>
</body>
</html>