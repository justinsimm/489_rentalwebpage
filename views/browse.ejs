<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Browse Listings</title>
    <link rel="stylesheet" href="/stylesheets/browse.css">
</head>
<body>
    <%- include('partials/navbar') %>
    <div class="background">
        <div class="border">
            <main class="container">
                <h1>Browse Listings</h1>
                <p class="subtitle">Find available rentals in your community.</p>

                <form class="searchBar" method="get" action="/browse">
                    <input id="searchInput" name="q" type="text" placeholder="Search items..." value="<%= search %>">
                    <select id="categoryFilter" name="category">
                        <option value="">All Categories</option>
                        <option value="Party & Events" <%= category === 'Party & Events' ? 'selected' : '' %>>Party & Events</option>
                        <option value="Tools & Equipment" <%= category === 'Tools & Equipment' ? 'selected' : '' %>>Tools & Equipment</option>
                        <option value="Electronics" <%= category === 'Electronics' ? 'selected' : '' %>>Electronics</option>
                        <option value="Sports & Outdoors" <%= category === 'Sports & Outdoors' ? 'selected' : '' %>>Sports & Outdoors</option>
                        <option value="Apparel & Formal Wear" <%= category === 'Apparel & Formal Wear' ? 'selected' : '' %>>Apparel & Formal Wear</option>
                    </select>
                    <button class="btn btnPrimary" type="submit">Search</button>
                </form>

                <% const listingItems = Array.isArray(items) ? items : []; %>
                <p class="resultsCount"><%= listingItems.length %> item(s) found</p>

                <% if (listingItems.length === 0) { %>
                    <div class="emptyState">
                        <p>No items match your search. Try a different keyword or category.</p>
                    </div>
                <% } else { %>
                    <div class="listingList">
                        <% listingItems.forEach(function(item) { %>
                            <a href="/item/<%= item._id %>" class="listingRow">
                                <div class="listingImage">
                                    <% if (item.image) { %>
                                        <img src="<%= item.image %>">
                                    <% } else { %>
                                        <div class="noImage">No Image</div>
                                    <% } %>
                                </div>
                                <div class="listingInfo">
                                    <h3 class="listingName"><%= item.name %></h3>
                                    <p class="listingOwner">Listed by: <%= item.owner %></p>
                                    <span class="listingCategory"><%= item.category || 'Other' %></span>
                                </div>
                                <div class="listingRight">
                                    <span class="listingPrice">$<%= item.dailyRate %>/day</span>
                                    <span class="listingStatus <%= item.status === 'Available' ? 'statusAvailable' : 'statusTaken' %>"><%= item.status %></span>
                                </div>
                            </a>
                        <% }); %>
                    </div>
                <% } %>
            </main>
        </div>
    </div>
</body>
</html>